# Bootstrap
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://uix:uix@localhost:5432/uix?schema=public"

# Auth
BETTER_AUTH_SECRET= # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# Secret key
CONFIG_ENCRYPTION_KEY= # openssl rand -base64 32

# Seed (superadmin bootstrap — the API runs the DB seed)
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD="change-me-please"
