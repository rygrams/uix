# =============================================================================
# Variables d'environnement chargées par le process de l'API (runtime).
# Copier ce fichier en `.env` et renseigner les valeurs.
# =============================================================================

PORT=3000

NODE_ENV=development

# -----------------------------------------------------------------------------
# Base de données (consommée par @app/database au runtime)
# -----------------------------------------------------------------------------

# Connexion directe à PostgreSQL.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Optionnel : connexion poolée (PgBouncer). Utilisée en priorité si définie.
# PGBOUNCER_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:6432/${POSTGRES_DB}?schema=public&pgbouncer=true"

# -----------------------------------------------------------------------------
# Authentification (consommée par @app/auth au runtime — cf. packages/auth/README.md)
# -----------------------------------------------------------------------------

BETTER_AUTH_SECRET= # `openssl rand -base64 32`
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Mail (consommée par MailService au runtime)
# -----------------------------------------------------------------------------

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
# Optionnel : requis uniquement si le serveur SMTP demande une authentification.
# MAIL_USER=
# MAIL_PASSWORD=
MAIL_FROM_NAME=Prod Dev Boilerplate
MAIL_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Stockage objet (consommée par StorageService au runtime — compatible MinIO)
# -----------------------------------------------------------------------------
RUSTFS_ENDPOINT=localhost
RUSTFS_ACCESS_KEY=minioadmin
RUSTFS_SECRET_KEY=minioadmin
RUSTFS_API_PORT=9000
# Mettre à `true` pour activer les connexions sécurisées (HTTPS).
RUSTFS_USE_SSL=false
RUSTFS_BUCKET=app
