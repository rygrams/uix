{
  "name": "@app/validators",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
